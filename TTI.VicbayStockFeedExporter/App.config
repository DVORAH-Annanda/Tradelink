<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

	<connectionStrings>
		<!--<add name="TTISqlConnection"
     connectionString="Data Source=TRADETTI2SERV\SQLEXPRESS;
                               Initial Catalog=TTI2;
                               User ID=david;
                               Password=TTIAdmin98;
                               MultipleActiveResultSets=True;"
     providerName="System.Data.SqlClient" />-->

		<add name="TTISqlConnection"
			connectionString="Data Source=ANNANDA\SQLEXPRESS; Initial Catalog=TTI2;           
         Integrated Security=True;                                
         MultipleActiveResultSets=True;"
		providerName="System.Data.SqlClient" />
	</connectionStrings>

	<appSettings>
		<!-- Required: Set this to the WhStore_Id for the central warehouse. -->
		<add key="CentralWarehouseId" value="39" />

		<!-- Recommended: write to a local folder first. Later this can be a web-accessible IIS folder. -->
		<add key="OutputPath" value="C:\Users\Dvorah\Source\Tradelink\TradeLinkJobs\VicbayStockFeedRepository\vicbay-stock.json" />

		<!-- Keep true initially so the website can treat missing/zero stock clearly. -->
		<add key="IncludeZeroStock" value="true" />

		<!-- Set true only if TLSOH_Sold definitely means unavailable for the website feed. -->
		<add key="ExcludeSoldStock" value="true" />

		<add key="WarehouseCode" value="TLWID39" />
		<add key="WarehouseDescription" value="Tradelink Central Warehouse" />

		<add key="PublishToGitHub" value="true" />
		<add key="GitRepositoryPath"
			 value="C:\Users\Dvorah\Source\Tradelink\TradeLinkJobs\VicbayStockFeedRepository" />
		<add key="GitExecutablePath"
			 value="C:\Program Files\Git\cmd\git.exe" />
		<add key="GitBranch" value="main" />
	</appSettings>
</configuration>
